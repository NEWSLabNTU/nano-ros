@PACKAGE_INIT@

# Phase 115.K.2.5: makes `find_package(NrosRmwXrce CONFIG)` resolve
# the imported target `NrosRmwXrce::NrosRmwXrce`. Downstream
# consumers (nros-c, nros-cpp) link against it when
# `NANO_ROS_RMW=xrce-c` is selected; the auto-register hook lives
# inline in `nros::init` (gated by `NROS_RMW_XRCE=1`).

include("${CMAKE_CURRENT_LIST_DIR}/NrosRmwXrceTargets.cmake")

check_required_components(NrosRmwXrce)
