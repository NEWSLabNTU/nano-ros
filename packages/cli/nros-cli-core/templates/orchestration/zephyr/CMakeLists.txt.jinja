# Phase 126.M5.zephyr — Generated by `nros build`.
#
# Zephyr integrates Rust through zephyr-lang-rust's
# `rust_cargo_application()` CMake function, which takes the
# adjacent Cargo.toml + src/lib.rs (crate-type=staticlib,
# name="rustapp") and produces a Zephyr app archive that's
# linked against the rest of the kernel image.
#
# RMW choice flows from Kconfig overlays (prj-<rmw>.conf) →
# CONFIG_NROS_RMW_<X>=y → EXTRA_CARGO_ARGS. Until the
# orchestrator emits a separate RMW overlay per plan, the
# generated package builds with the cargo `default` features
# that the orchestrator already pinned in Cargo.toml.

cmake_minimum_required(VERSION 3.20.0)

find_package(Zephyr REQUIRED HINTS $ENV{ZEPHYR_BASE})
project({{ package_name }})

rust_cargo_application()
