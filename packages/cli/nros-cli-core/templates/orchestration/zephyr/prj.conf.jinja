# Phase 126.M5.zephyr — Generated by `nros build`.
#
# Base Kconfig for Zephyr generated orchestration package. Builds
# on the common subset shared by the multi-RMW Zephyr examples at
# `examples/zephyr/rust/`. Per-RMW overlays (zenoh / xrce /
# cyclonedds) are still added separately by the user via
# -DCONF_FILE; the orchestrator's role at this milestone is the
# Rust + Zephyr POSIX glue, not the RMW transport sizing.

# Rust support (zephyr-lang-rust).
CONFIG_RUST=y
CONFIG_RUST_ALLOC=y

# Logging.
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_PRINTK=y
CONFIG_EARLY_CONSOLE=y

# Networking (common to all RMW backends nano-ros ships).
CONFIG_NETWORKING=y
CONFIG_NET_IPV4=y
CONFIG_NET_UDP=y
CONFIG_NET_SOCKETS=y
CONFIG_NET_L2_ETHERNET=y
CONFIG_NET_MAX_CONTEXTS=16
CONFIG_DNS_RESOLVER=n

# POSIX pthread sizing — zenoh-pico needs ≥8 mutexes (Phase 88
# notes in MEMORY.md: write-filter mutex per publisher).
CONFIG_MAX_PTHREAD_MUTEX_COUNT=32
CONFIG_MAX_PTHREAD_COND_COUNT=16

# Timing.
CONFIG_SYS_CLOCK_TICKS_PER_SEC=1000

# nros Zephyr module.
CONFIG_NROS=y
CONFIG_NROS_RUST_API=y
