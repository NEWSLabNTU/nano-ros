@PACKAGE_INIT@

# Phase 123.A.1.x.2: makes `find_package(NrosPlatformPosix CONFIG)`
# resolve the imported target `NrosPlatformPosix::nros_platform_posix`.
# Downstream consumers (`NanoRos::NanoRos` on POSIX) link against it
# to supply the canonical `nros_platform_*` C ABI symbols. Replaces
# the Rust `nros-platform-posix` crate deleted by the same sub-phase.

include(CMakeFindDependencyMacro)
# `nros_platform_posix` carries `Threads::Threads` as a PUBLIC link
# dep; downstream consumers need it surfaced via find_package() so
# the imported target resolves.
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/NrosPlatformPosixTargets.cmake")

check_required_components(NrosPlatformPosix)
