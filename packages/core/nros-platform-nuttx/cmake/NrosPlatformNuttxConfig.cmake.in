@PACKAGE_INIT@

# Phase 123.A.1.x.3: `find_package(NrosPlatformNuttx CONFIG)` resolves
# the imported target `NrosPlatformNuttx::nros_platform_nuttx`. The
# NuttX C port delegates to nros-platform-posix's source (POSIX-
# compatible surface) — see `packages/core/nros-platform-nuttx/
# CMakeLists.txt`. NuttX's own libc supplies pthread + libc functions;
# parent NuttX build pulls them in automatically.

include("${CMAKE_CURRENT_LIST_DIR}/NrosPlatformNuttxTargets.cmake")

check_required_components(NrosPlatformNuttx)
