@PACKAGE_INIT@

# Phase 123.A.1.x.3: `find_package(NrosPlatformFreertos CONFIG)`
# resolves the imported target
# `NrosPlatformFreertos::nros_platform_freertos`. Downstream
# consumers link against it to supply the canonical
# `nros_platform_*` C ABI symbols when targeting FreeRTOS.
#
# The C-port itself does NOT pull in FreeRTOS-Kernel headers via
# `find_package` — the parent build must declare the kernel target
# (`FREERTOS_KERNEL_TARGET`, default `freertos_kernel`) before the
# imported target's PUBLIC link line resolves.

include("${CMAKE_CURRENT_LIST_DIR}/NrosPlatformFreertosTargets.cmake")

check_required_components(NrosPlatformFreertos)
