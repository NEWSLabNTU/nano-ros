@PACKAGE_INIT@

# nros-c CMake configuration
#
# This file is installed when nros-c is installed and provides:
# - nano_ros_c::nano_ros_c target (imported library)
# - nano_ros_generate_interfaces() function
#
# Usage:
#   find_package(nano_ros_c REQUIRED)
#   target_link_libraries(my_app nano_ros_c::nano_ros_c)

include(CMakeFindDependencyMacro)

# Include the generator function
include("${CMAKE_CURRENT_LIST_DIR}/nano_ros_generate_interfaces.cmake")

# Include the targets
include("${CMAKE_CURRENT_LIST_DIR}/nano_ros_cTargets.cmake")

check_required_components(nano_ros_c)
