# Doxyfile for nros C API documentation
#
# Usage: doxygen packages/core/nros-c/Doxyfile
# Or:    just doc-c

PROJECT_NAME           = "nros C API"
PROJECT_BRIEF          = "Lightweight ROS 2 client for embedded real-time systems"

# Input: hand-written per-module headers + mainpage
# Exclude nros_generated.h (internal cbindgen artifact for drift detection)
INPUT                  = include/nros/nros.h \
                         include/nros/types.h \
                         include/nros/init.h \
                         include/nros/node.h \
                         include/nros/publisher.h \
                         include/nros/subscription.h \
                         include/nros/service.h \
                         include/nros/client.h \
                         include/nros/executor.h \
                         include/nros/timer.h \
                         include/nros/guard_condition.h \
                         include/nros/lifecycle.h \
                         include/nros/action.h \
                         include/nros/parameter.h \
                         include/nros/cdr.h \
                         include/nros/clock.h \
                         include/nros/visibility.h \
                         include/nros/platform.h \
                         docs/mainpage.md \
                         docs/getting-started.md \
                         docs/configuration.md \
                         docs/ros2-interop.md \
                         docs/troubleshooting.md
RECURSIVE              = NO
FILE_PATTERNS          = *.h *.md
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

# Output alongside rustdoc under target/doc/
OUTPUT_DIRECTORY       = ../../../target/doc/c-api

# C-optimised output
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES

# Extract everything so the generated site is complete even when finer-grained
# (per-param / per-field) docs are missing. Real doc errors still surface via
# WARN_IF_DOC_ERROR; missing-doc nags are off because they would dominate the
# build log on every public-facing rebuild.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES

WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# No LaTeX, just HTML
GENERATE_HTML          = YES
GENERATE_LATEX         = NO

# Preprocessing: expand NROS_PUBLIC so Doxygen sees the declarations
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = NROS_PUBLIC=

# Sort members alphabetically within their sections
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
