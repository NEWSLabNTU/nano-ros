<?xml version="1.0"?>
<!--
  Phase 212.O.5 fixture — secondary launch.xml.

  Shipped inside the `secondary_node` package and pulled into the
  primary launch via `<include file="$(find secondary_node)/launch/secondary.launch.xml"/>`.
  Copy-paste shape from nav2's `bringup/launch/localization_launch.py`
  / robot_state_publisher's `launch/rsp.launch.xml` sub-includes:
  a single `<arg>` declaration with a default, then one `<node>` that
  binds a `<param>` to the arg's substitution. The integration test
  asserts the resolved param value (the default propagated from this
  `<arg>`) appears in the codegen-emitted plan.
-->
<launch>
  <arg name="frame_id" default="base_link"/>

  <node pkg="secondary_node" exec="secondary" name="secondary">
    <param name="frame_id" value="$(var frame_id)"/>
    <remap from="status" to="secondary/status"/>
  </node>
</launch>
