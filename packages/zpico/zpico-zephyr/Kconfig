menuconfig NANO_ROS_BSP
    bool "nros Board Support Package"
    depends on ZENOH_PICO
    help
      Enable nros BSP for simplified ROS 2 node development.
      This provides a high-level API that hides zenoh-pico details.

if NANO_ROS_BSP

config NANO_ROS_DOMAIN_ID
    int "ROS 2 Domain ID"
    default 0
    help
      ROS 2 domain ID for topic isolation.

config NANO_ROS_ZENOH_LOCATOR
    string "Zenoh router locator"
    default "tcp/192.0.2.2:7447"
    help
      Zenoh router address. Supported formats:
        TCP:    "tcp/IP:PORT"       (e.g. "tcp/192.0.2.2:7447")
        Serial: "serial/DEVICE#baudrate=RATE" (e.g. "serial/uart1#baudrate=115200")

config NANO_ROS_NODE_NAME
    string "Default node name"
    default "nros_node"
    help
      Default name for the ROS 2 node.

config NANO_ROS_MAX_PUBLISHERS
    int "Maximum number of publishers"
    default 4
    help
      Maximum number of publishers per node.

config NANO_ROS_MAX_SUBSCRIBERS
    int "Maximum number of subscribers"
    default 4
    help
      Maximum number of subscribers per node.

config NANO_ROS_MAX_SERVICES
    int "Maximum number of services per node"
    default 4
    help
      Maximum number of service servers per node.

config NANO_ROS_MAX_TIMERS
    int "Maximum number of timers per node"
    default 8
    help
      Maximum number of timers per node.

config NANO_ROS_MAX_NODES
    int "Maximum number of nodes per executor"
    default 4
    help
      Maximum number of nodes managed by one executor.

config NANO_ROS_INIT_DELAY_MS
    int "Initialization delay (ms)"
    default 2000
    help
      Delay before initializing zenoh to allow network to settle.

config NANO_ROS_TRANSPORT_SERIAL
    bool "Enable serial/UART transport"
    select ZENOH_PICO_LINK_SERIAL
    help
      Enable serial/UART transport for zenoh-pico.
      Use with a serial locator, e.g.:
        CONFIG_NANO_ROS_ZENOH_LOCATOR="serial/uart1#baudrate=115200"

config NANO_ROS_AUTO_INIT
    bool "Automatic initialization"
    default n
    help
      Automatically initialize nros BSP at boot.
      If disabled, call nano_ros_bsp_init() manually.

endif # NANO_ROS_BSP
