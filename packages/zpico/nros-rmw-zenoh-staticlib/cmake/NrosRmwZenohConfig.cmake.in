@PACKAGE_INIT@

# Phase 128.H.8 — pick the per-platform staticlib that matches the
# consumer's `NANO_ROS_PLATFORM`. Previously the install wrote a
# single `IMPORTED_LOCATION` that pointed at whichever platform was
# installed LAST, so a host build that follows a cross-install
# (threadx_riscv64 + posix) ended up linking the wrong archive
# (caught while running `just ci`'s c-msg-gen test).
if(NOT DEFINED NANO_ROS_PLATFORM)
    set(NANO_ROS_PLATFORM "posix")
endif()

if(NANO_ROS_PLATFORM STREQUAL "posix")
    set(_NROS_RMW_ZENOH_LIB
        "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libnros_rmw_zenoh.a")
else()
    set(_NROS_RMW_ZENOH_LIB
        "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libnros_rmw_zenoh_${NANO_ROS_PLATFORM}.a")
endif()

if(NOT EXISTS "${_NROS_RMW_ZENOH_LIB}")
    set(NrosRmwZenoh_FOUND FALSE)
    return()
endif()

if(NOT TARGET NrosRmwZenoh::NrosRmwZenoh)
    add_library(NrosRmwZenoh::NrosRmwZenoh STATIC IMPORTED)
    set_target_properties(NrosRmwZenoh::NrosRmwZenoh PROPERTIES
        IMPORTED_LOCATION "${_NROS_RMW_ZENOH_LIB}")
endif()

check_required_components(NrosRmwZenoh)
