<?xml version="1.0"?>
<!-- Phase 269 W3 catalog launch for the cross-process C++ E2E-safety demo. Lists BOTH
     nodes so `nros codegen-system` (invoked without an explicit file argument) resolves
     an unambiguous system catalog. In-process delivery does not happen (same zenoh
     session; issue 0096), so the talker and safe_listener actually run as TWO
     processes: native_safety_talker_entry boots safety_talker.launch.xml and
     native_safety_listener_entry boots safety_listener.launch.xml. -->
<launch>
  <node pkg="cpp_safety_talker_pkg" exec="talker" name="talker"/>
  <node pkg="cpp_safety_listener_pkg" exec="safe_listener" name="safe_listener"/>
</launch>
