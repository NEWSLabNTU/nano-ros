<?xml version="1.0"?>
<!-- Phase 269 W3 — listener half of the cross-process C++ E2E-safety demo.
     Boots the C++ validated listener: validates CRC via
     `node.create_subscription_with_safety()` and republishes the running CRC-valid
     count on /safe_ok. Run in a separate process from `safety_talker.launch.xml`.
     Boot with `native_safety_listener_entry`. -->
<launch>
  <node pkg="cpp_safety_listener_pkg" exec="safe_listener" name="safe_listener"/>
</launch>
