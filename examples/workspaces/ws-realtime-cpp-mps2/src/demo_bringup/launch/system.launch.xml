<?xml version="1.0"?>
<!-- Phase 274.W3 / phase-144 (#144) (ws-realtime-cpp-mps2) — 3-node, 3-tier C++
     entry on FreeRTOS/mps2. Node `name`s must match system.toml [[component]].name
     (RFC-0032 §7). aux_node is the mid tier (spawned by a spawned tier) that
     proves the #144 chained-spawn fix. -->
<launch>
    <node pkg="ctrl_pkg" exec="ctrl" name="ctrl_node"/>
    <node pkg="aux_pkg" exec="aux" name="aux_node"/>
    <node pkg="telem_pkg" exec="telem" name="telem_node"/>
</launch>
