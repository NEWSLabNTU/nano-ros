# Phase 157 — NuttX external-app Kconfig for the CPP listener example.
# Sourced from `integrations/nuttx/Kconfig` via osource glob.

config NROS_EXAMPLE_LISTENER_CPP
    tristate "nano-ros: CPP listener (zenoh)"
    default n
    depends on NROS && NROS_CPP_API
    ---help---
        Subscribes to std_msgs/msg/Int32 on /chatter and prints each message.
        Built-in command name: `nuttx_cpp_listener`.
