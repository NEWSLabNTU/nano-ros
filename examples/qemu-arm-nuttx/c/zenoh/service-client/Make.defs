# Phase 157 — NuttX external-app Make.defs for the C service-client example.
# Discovered by NuttX's apps/Makefile via the `apps/external/*/Make.defs`
# glob. Sibling `integrations/nuttx/Make.defs` exposes nano-ros headers +
# `libnros_c.a` via the parent CONFIG_NROS gate.

ifneq ($(CONFIG_NROS_EXAMPLE_SERVICE_CLIENT_C),)
CONFIGURED_APPS += $(APPDIR)/external/nano-ros-service-client-c
endif
