# Phase 157 — NuttX external-app Kconfig for the C service-client example.
# Sourced from `integrations/nuttx/Kconfig` via osource glob.

config NROS_EXAMPLE_SERVICE_CLIENT_C
    tristate "nano-ros: C service-client (zenoh)"
    default n
    depends on NROS && NROS_C_API
    ---help---
        Calls example_interfaces/srv/AddTwoInts on /add_two_ints and prints the result.
        Built-in command name: `nuttx_c_service_client`.
