# Phase 157 — NuttX external-app Kconfig for the C listener example.
# Sourced from `integrations/nuttx/Kconfig` via osource glob.

config NROS_EXAMPLE_LISTENER_C
    tristate "nano-ros: C listener (zenoh)"
    default n
    depends on NROS && NROS_C_API
    ---help---
        Subscribes to std_msgs/msg/Int32 on /chatter and prints each message.
        Built-in command name: `nuttx_c_listener`.
