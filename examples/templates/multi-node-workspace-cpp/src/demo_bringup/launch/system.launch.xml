<?xml version="1.0"?>
<!-- ROS 2 launch schema, verbatim. The typed Entry routes each <node> to
     its C++ component object on the real executor (RFC-0043). -->
<launch>
  <!-- Phase 211.H (issue #52) — a per-topic QoS override on the talker. The
       typed C++ entry codegen bakes a `set_qos_overrides` call before
       `configure(node)`, so the talker's /chatter publisher is created
       best_effort. Exercises the full cmake C++ pipeline: launch param →
       emit_cpp bake → built entry honours the override at create time. -->
  <node pkg="talker_pkg" exec="talker" name="talker">
    <param name="qos_overrides./chatter.publisher.reliability" value="best_effort"/>
  </node>
  <node pkg="listener_pkg" exec="listener" name="listener"/>
</launch>
