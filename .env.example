# nano-ros Environment Variables
#
# Copy this file to .env and uncomment the variables you want to override.
# The .env file is gitignored and will not be committed.
#
# justfile auto-loads .env (set dotenv-load). direnv sources it via .envrc.
# Variables here take precedence over justfile defaults but are overridden
# by explicit shell exports.

# =============================================================================
# Runtime Configuration
# =============================================================================

# ROS 2 domain ID (default: 0)
#ROS_DOMAIN_ID=0

# Zenoh router address — tcp/…, udp/…, or tls/… (default: tcp/127.0.0.1:7447)
#ZENOH_LOCATOR=tcp/127.0.0.1:7447

# Zenoh session mode: client or peer (default: client)
#ZENOH_MODE=client

# Path to CA certificate (PEM) for TLS (POSIX only)
#ZENOH_TLS_ROOT_CA_CERTIFICATE=

# Base64-encoded CA certificate for TLS (works on bare-metal too)
#ZENOH_TLS_ROOT_CA_CERTIFICATE_BASE64=

# Verify server hostname in TLS: true or false
#ZENOH_TLS_VERIFY_NAME_ON_CONNECT=

# =============================================================================
# Platform SDK Paths
# =============================================================================
# Auto-resolved by justfile to external/ defaults from `just setup`.

# FreeRTOS kernel source (default: external/freertos-kernel)
#FREERTOS_DIR=

# FreeRTOS portable layer (default: GCC/ARM_CM3)
#FREERTOS_PORT=GCC/ARM_CM3

# lwIP source (default: external/lwip)
#LWIP_DIR=

# FreeRTOSConfig.h + lwipopts.h directory
#FREERTOS_CONFIG_DIR=

# NuttX RTOS source (default: external/nuttx)
#NUTTX_DIR=

# ThreadX RTOS source (default: external/threadx)
#THREADX_DIR=

# ThreadX config directory
#THREADX_CONFIG_DIR=

# NetX Duo source (default: external/netxduo)
#NETX_DIR=

# NetX Duo config directory
#NETX_CONFIG_DIR=

# =============================================================================
# Build-Time Configuration
# =============================================================================

# CMake install prefix for pre-built zenoh-pico (only with system-zenohpico feature)
#ZENOH_PICO_DIR=

# WiFi credentials for ESP32 examples
#SSID=
#PASSWORD=

# =============================================================================
# Zenoh-pico Buffer Tuning (ZPICO_*)
# =============================================================================
# All optional — platform-appropriate defaults apply if unset.
# Dual defaults shown as posix/embedded.

# Max reassembled message size after defragmentation (default: 65536 / 2048)
#ZPICO_FRAG_MAX_SIZE=65536

# Max unicast batch size before fragmentation (default: 65536 / 1024)
#ZPICO_BATCH_UNICAST_SIZE=65536

# Max multicast batch size (default: 8192 / 1024)
#ZPICO_BATCH_MULTICAST_SIZE=8192

# Max concurrent publishers in zenoh shim (default: 8)
#ZPICO_MAX_PUBLISHERS=8

# Max concurrent subscribers in zenoh shim (default: 8)
#ZPICO_MAX_SUBSCRIBERS=8

# Max concurrent queryables in zenoh shim (default: 8)
#ZPICO_MAX_QUERYABLES=8

# Max concurrent liveliness tokens in zenoh shim (default: 16)
#ZPICO_MAX_LIVELINESS=16

# Max concurrent in-flight service calls (default: 4)
#ZPICO_MAX_PENDING_GETS=4

# Per-subscriber static buffer in zenoh shim (default: 1024)
#ZPICO_SUBSCRIBER_BUFFER_SIZE=1024

# Per-service-server static buffer in zenoh shim (default: 1024)
#ZPICO_SERVICE_BUFFER_SIZE=1024

# Stack buffer for service client replies (default: 4096)
#ZPICO_GET_REPLY_BUF_SIZE=4096

# Single-threaded polling interval in zenoh_shim_get(), ms (default: 10)
#ZPICO_GET_POLL_INTERVAL_MS=10

# Max concurrent TCP sockets — smoltcp only (default: 4)
#ZPICO_SMOLTCP_MAX_SOCKETS=4

# Max concurrent UDP sockets — smoltcp only (default: 2)
#ZPICO_SMOLTCP_MAX_UDP_SOCKETS=2

# Per-socket staging buffer — smoltcp only (default: 2048)
#ZPICO_SMOLTCP_BUFFER_SIZE=2048

# TCP connection timeout, ms — smoltcp only (default: 30000)
#ZPICO_SMOLTCP_CONNECT_TIMEOUT_MS=30000

# TCP read/write timeout, ms — smoltcp only (default: 10000)
#ZPICO_SMOLTCP_SOCKET_TIMEOUT_MS=10000

# =============================================================================
# XRCE-DDS Buffer Tuning (XRCE_*)
# =============================================================================
# All optional — platform-appropriate defaults apply if unset.

# Custom transport MTU; also sizes stream buffers (4x MTU) and UDP staging (default: 4096 / 512)
#XRCE_TRANSPORT_MTU=4096

# Max concurrent subscribers (default: 8)
#XRCE_MAX_SUBSCRIBERS=8

# Max concurrent service servers (default: 4)
#XRCE_MAX_SERVICE_SERVERS=4

# Max concurrent service clients (default: 4)
#XRCE_MAX_SERVICE_CLIENTS=4

# Per-slot static buffer size (default: 1024)
#XRCE_BUFFER_SIZE=1024

# Reliable stream history depth, must be >= 2 (default: 4)
#XRCE_STREAM_HISTORY=4

# Timeout for entity creation, ms (default: 1000)
#XRCE_ENTITY_CREATION_TIMEOUT_MS=1000

# Timeout for service replies, ms (default: 1000)
#XRCE_SERVICE_REPLY_TIMEOUT_MS=1000

# Number of service reply retries (default: 5)
#XRCE_SERVICE_REPLY_RETRIES=5

# Max session connection attempts (default: 10)
#XRCE_MAX_SESSION_CONNECTION_ATTEMPTS=10

# Min interval between connection attempts, ms (default: 25)
#XRCE_MIN_SESSION_CONNECTION_INTERVAL=25

# Min heartbeat interval, ms (default: 100)
#XRCE_MIN_HEARTBEAT_TIME_INTERVAL=100

# In-flight UDP packets per direction — smoltcp only (default: 4)
#XRCE_UDP_META_COUNT=4

# =============================================================================
# Core Tuning (NROS_*)
# =============================================================================

# --- nros-node (Rust API) ---

# Max executor callback slots — controls static array size at compile time (default: 4)
#NROS_EXECUTOR_MAX_CBS=4

# Subscription/service receive buffer size, bytes (default: 1024)
# Arena size is derived automatically: max_cbs * (rx_buf * 2 + 256) + 1024
#NROS_SUBSCRIPTION_BUFFER_SIZE=1024

# --- nros-c (C API) ---

# Buffer size for LET semantics per handle (default: 512)
#NROS_LET_BUFFER_SIZE=512

# --- nros-params ---

# Max parameters in parameter server (default: 32)
#NROS_MAX_PARAMETERS=32

# Max parameter name length (default: 64)
#NROS_MAX_PARAM_NAME_LEN=64

# Max string parameter value length (default: 256)
#NROS_MAX_STRING_VALUE_LEN=256

# Max parameter array length (default: 32)
#NROS_MAX_ARRAY_LEN=32

# Max byte array parameter length (default: 256)
#NROS_MAX_BYTE_ARRAY_LEN=256
