# Source ROS2 Humble
if [[ -f /opt/ros/humble/setup.bash ]]; then
    source /opt/ros/humble/setup.bash
else
    echo "Warning: /opt/ros/humble/setup.bash not found"
fi

# Put the `nros` build tool on PATH. It ships from the standalone
# NEWSLabNTU/nros-cli repo (Phase 195.D — the in-tree codegen submodule was
# retired) and `scripts/install-nros.sh` installs it to $NROS_HOME/bin
# (default ~/.nros/bin), which is not otherwise on PATH. cmake's
# `nros_generate_interfaces` already searches ~/.nros/bin, but direct
# `nros codegen` / `nros generate-rust` calls need it here.
if [[ -x "${NROS_HOME:-$HOME/.nros}/bin/nros" ]]; then
    export PATH="${NROS_HOME:-$HOME/.nros}/bin:$PATH"
fi

# Prefer the pinned ninja (>=1.13, GNU-jobserver client — Phase 176)
# installed by `just workspace install-ninja`, over Ubuntu's apt 1.10.
if [[ -x "$PWD/third-party/ninja/ninja" ]]; then
    export PATH="$PWD/third-party/ninja:$PATH"
fi

# Prefer the pinned GNU make (>=4.4, fifo jobserver — Phase 176)
# installed by `just workspace install-make`, over Ubuntu's 4.3.
if [[ -x "$PWD/third-party/make/make" ]]; then
    export PATH="$PWD/third-party/make:$PATH"
fi

# Load project .env overrides for variables such as runtime config, buffer
# tuning, and SDK paths. Then load any missing SDK defaults from the same
# just/sdk-env.just SSoT used by just recipes.
if type -t dotenv_if_exists &>/dev/null; then
    dotenv_if_exists .env
fi
source scripts/sdk-env.sh
