# Source ROS2 Humble
if [[ -f /opt/ros/humble/setup.bash ]]; then
    source /opt/ros/humble/setup.bash
else
    echo "Warning: /opt/ros/humble/setup.bash not found"
fi

# FreeRTOS + lwIP (install via: just setup-freertos)
export FREERTOS_DIR="${PWD}/external/freertos-kernel"
export FREERTOS_PORT=GCC/ARM_CM3
export LWIP_DIR="${PWD}/external/lwip"
export FREERTOS_CONFIG_DIR="${PWD}/packages/boards/nros-mps2-an385-freertos/config"
