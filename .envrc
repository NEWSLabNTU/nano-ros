# Source ROS2 Humble
if [[ -f /opt/ros/humble/setup.bash ]]; then
    source /opt/ros/humble/setup.bash
else
    echo "Warning: /opt/ros/humble/setup.bash not found"
fi

# Default toolchain source paths (direnv `PROJECT_DIR` points at this .envrc's
# directory). Each var is only exported if it isn't already set, so users can
# override any one of them by exporting it in a shell or in .env before cd'ing
# into the project. The justfile independently falls back to the same defaults
# via `env(...)` in its top-level `export` statements.
: "${NUTTX_DIR:=$PWD/third-party/nuttx/nuttx}"
: "${NUTTX_APPS_DIR:=$PWD/third-party/nuttx/nuttx-apps}"
: "${THREADX_DIR:=$PWD/third-party/threadx/kernel}"
: "${NETX_DIR:=$PWD/third-party/threadx/netxduo}"
: "${FREERTOS_DIR:=$PWD/third-party/freertos/kernel}"
: "${LWIP_DIR:=$PWD/third-party/freertos/lwip}"
export NUTTX_DIR NUTTX_APPS_DIR THREADX_DIR NETX_DIR FREERTOS_DIR LWIP_DIR

# Load project .env overrides for other variables (runtime config, buffer
# tuning, etc. — see .env.example). Uses direnv's stdlib `dotenv_if_exists`
# which is a no-op when called outside a direnv context (e.g. manual source).
if type -t dotenv_if_exists &>/dev/null; then
    dotenv_if_exists .env
fi
