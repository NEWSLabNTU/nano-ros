// Generated by nano_ros_node_register(TYPED) — FreeRTOS bootable-ELF carrier
// entry, typed (RFC-0043 / RFC-0044). DO NOT EDIT (regenerated at configure
// time from cmake/templates/freertos_entry_main_typed.cpp.in).
//
// Routes the single registered Node pkg to the REAL executor and runs
// `FreertosBoard::run_components` (init → setup → spin_once loop → shutdown). No
// synthesizing interpreter, no `__nros_component_*_register`, no `NodeContext`.
//
// FreeRTOS boot: the board `startup.c` `_start` spawns the `app` task and calls
// `vTaskStartScheduler()`; that task's `app_task_entry` brings up LAN9118 + lwIP
// + the net-poll task + the zenoh read/lease task config, then dispatches to
// this `app_main` (kernel + network already up), so `FreertosBoard::run_components`
// brings the runtime online WITHOUT re-entering the kernel — same shape as the
// NuttX carrier.
//
// Shape-branched (Phase 242.4, @NROS_ENTRY_SHAPE_RCLCPP@ set by cmake):
//   * configure (RFC-0043, 240.3) — default-construct the component, then
//     `configure(node)` binds the real member callbacks by identity.
//   * rclcpp (RFC-0044) — the component IS-A node: placement-new it with the
//     executor node handle *after* init (its ctor creates the node + entities),
//     then check `ok()` and halt boot naming the node on failure.

// Phase 240.6 — opt-in boot diagnostics. Define `NROS_FREERTOS_ENTRY_DEBUG` to
// print init/setup/spin progress over the FreeRTOS semihosting console.

#include <nros/app_main.h>
#include <nros/component.hpp>
#include <nros/component_node.hpp>
#include <nros/main.hpp>
#include <nros/nros.hpp>

#include <new>

#include "@NROS_ENTRY_CLASS_HEADER@"

// cmake sets this to 1 for the rclcpp (construct-with-handle) shape, 0 for the
// legacy configure(Node&) shape.
#define NROS_ENTRY_SHAPE_RCLCPP @NROS_ENTRY_SHAPE_RCLCPP@

#if NROS_ENTRY_SHAPE_RCLCPP

// rclcpp shape: the component owns its node. An aligned arena slot holds it;
// it is placement-new'd in setup, after init, with the executor node handle.
alignas(::@NROS_ENTRY_CLASS@) static unsigned char __nros_comp_buf[sizeof(::@NROS_ENTRY_CLASS@)];
static ::@NROS_ENTRY_CLASS@* __nros_comp = nullptr;

static int32_t __nros_entry_setup() {
    ::nros::NodeHandle handle(::nros::global_handle());
    if (!handle.valid()) {
        return static_cast<int32_t>(::nros::ErrorCode::NotInitialized);
    }
    __nros_comp = new (__nros_comp_buf) ::@NROS_ENTRY_CLASS@(handle);
    if (!__nros_comp->ok()) {
        ::nros::detail::report_component_failure("@NROS_ENTRY_NODE_NAME@", __nros_comp->error_what(),
                                                 __nros_comp->error_code());
        return __nros_comp->error_code();
    }
    return 0;
}

#else

// configure shape: the node + component outlive the spin loop (the executor
// holds `&__nros_comp` as the dispatch ctx). No heap.
static ::nros::Node __nros_node;
static ::@NROS_ENTRY_CLASS@ __nros_comp;

static int32_t __nros_entry_setup() {
    ::nros::Result r = ::nros::create_node(__nros_node, "@NROS_ENTRY_NODE_NAME@");
    if (!r.ok()) {
        return static_cast<int32_t>(r.raw());
    }
    r = __nros_comp.configure(__nros_node);
    if (!r.ok()) {
        return static_cast<int32_t>(r.raw());
    }
    return 0;
}

#endif // NROS_ENTRY_SHAPE_RCLCPP

extern "C" int nros_app_main(int /*argc*/, char** /*argv*/) {
#ifdef NROS_FREERTOS_ENTRY_DEBUG
    ::std::printf("[freertos-cpp] nros_app_main reached (typed @NROS_ENTRY_CLASS@)\n");
#endif
    // Baked connect locator (QEMU slirp host = 10.0.2.2). Empty string →
    // backend discovery default.
    return ::nros::board::FreertosBoard::run_components("@NROS_ENTRY_LOCATOR@", &__nros_entry_setup);
}

// FreeRTOS app entry: the board `startup.c` `app_task_entry` calls `app_main()`
// (declared `extern void app_main(void)`) after network + task bring-up. Emit
// `void app_main(void)` forwarding into nros_app_main.
NROS_APP_MAIN_REGISTER_VOID();
