/* Generated by nano_ros_node_register(TYPED ... DEPLOY freertos) — the FreeRTOS
 * carrier's NROS_APP_CONFIG definition. DO NOT EDIT (regenerated at configure
 * time from cmake/templates/freertos_app_config.c.in).
 *
 * Phase 240.6 (RFC-0043) — in the typed C/C++ carrier the bootable ELF is
 * linked from cmake (add_executable + nros_platform_link_app); the Rust board
 * crate `nros-board-mps2-an385-freertos` (whose build.rs emits NROS_APP_CONFIG
 * into the board staticlib for the Rust path) is NOT linked. The board's
 * `startup.c` — added to the app target via FREERTOS_STARTUP_SOURCE — reads
 * `NROS_APP_CONFIG` for the LAN9118/lwIP network bring-up + the FreeRTOS task
 * priorities/stacks, so the carrier supplies the symbol here.
 *
 * Values mirror `nros-board-mps2-an385-freertos/build.rs::emit_nros_app_config`
 * (itself mirroring `nros_board_freertos::Config::default()`). Keep in sync when
 * the board defaults change.
 *
 * `.zenoh.locator` is cosmetic on the typed C/C++ path: the connect locator the
 * runtime actually dials is baked into the generated entry TU
 * (`FreertosBoard::run_components("@NROS_ENTRY_LOCATOR@", ...)`), not read from
 * here. `.network.*` and `.scheduling.*` ARE consumed by startup.c.
 */

#include <stdint.h>
#include <nros/app_config.h>

const nros_app_config_t NROS_APP_CONFIG = {
    .zenoh = {
        .locator   = "@NROS_ENTRY_LOCATOR@",
        .domain_id = @NROS_ENTRY_APP_DOMAIN_ID@,
    },
    .network = {
        /* Last octet is per-image (@NROS_ENTRY_IP_LAST@, default 10): two QEMU
         * nodes of a test pair MUST differ — the board seeds its PRNG from
         * IP+MAC, and identical seeds give identical zenoh ZIDs, which the
         * router treats as ONE peer (max_links=1) → silent no-delivery
         * (phase-287 W6; same lesson as the threadx-riscv64 .40/.41 split). */
        .ip      = { 192, 0, 3, @NROS_ENTRY_IP_LAST@ },
        .mac     = { 0x02, 0x00, 0x00, 0x00, 0x00, @NROS_ENTRY_IP_LAST@ },
        .gateway = { 192, 0, 3, 1 },
        .netmask = { 255, 255, 255, 0 },
        .prefix  = 24,
    },
    .scheduling = {
        .app_priority            = 12,
        .zenoh_read_priority     = 16,
        .zenoh_lease_priority    = 16,
        .poll_priority           = 16,
        .app_stack_bytes         = 524288u,
        .zenoh_read_stack_bytes  = 5120u,
        .zenoh_lease_stack_bytes = 5120u,
        .poll_interval_ms        = 5u,
    },
};
