extern "C" int nros_app_main(int /*argc*/, char** /*argv*/) {
#ifdef NROS_THREADX_ENTRY_DEBUG
    ::std::printf("[threadx-cpp] nros_app_main reached (typed @NROS_ENTRY_CLASS@)\n");
#endif
    // Baked connect locator (QEMU slirp host = 10.0.2.2). Empty string →
    // backend discovery default. CycloneDDS ignores it (no router); domain id is
    // compile-time (`NROS_ENTRY_DOMAIN_ID`).
    return ::nros::board::ThreadxBoard::run_components("@NROS_ENTRY_LOCATOR@", &__nros_entry_setup);
}

// ThreadX board entry: the riscv64 `startup.c` registers `app_main` via
// `nros_threadx_set_app_main` and the link keeps it live (`-u app_main`). Emit
// `void app_main(void)` forwarding into nros_app_main.
NROS_APP_MAIN_REGISTER_VOID();
