// Defer to the toolchain's real <utility> when reachable; else the minimal shim.
#if defined(__has_include_next) && __has_include_next(<utility>)
#  include_next <utility>
#elif !defined(NROS_ZEPHYR_CXX_COMPAT_UTILITY)
#define NROS_ZEPHYR_CXX_COMPAT_UTILITY

namespace std {

template <class T>
struct remove_reference {
    using type = T;
};

template <class T>
struct remove_reference<T&> {
    using type = T;
};

template <class T>
struct remove_reference<T&&> {
    using type = T;
};

template <class T>
constexpr typename remove_reference<T>::type&& move(T&& value) noexcept {
    return static_cast<typename remove_reference<T>::type&&>(value);
}

} // namespace std

#endif // NROS_ZEPHYR_CXX_COMPAT_UTILITY
