// C++ compat for Zephyr picolibc targets without full libc++ headers.
// Defer to the toolchain's real <cstdio> when reachable; else the shim.
#if defined(__has_include_next) && __has_include_next(<cstdio>)
#  include_next <cstdio>
#elif !defined(NROS_ZEPHYR_CXX_COMPAT_CSTDIO)
#define NROS_ZEPHYR_CXX_COMPAT_CSTDIO
#include <stdio.h>

namespace std {
using ::FILE;
using ::fclose;
using ::fflush;
using ::fopen;
using ::fprintf;
using ::fputc;
using ::fputs;
using ::fread;
using ::fwrite;
using ::printf;
using ::puts;
using ::snprintf;
using ::sprintf;
using ::sscanf;
using ::vfprintf;
using ::vprintf;
using ::vsnprintf;
using ::vsprintf;
}
#endif
