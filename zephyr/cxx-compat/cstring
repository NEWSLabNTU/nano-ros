// C++ compat for Zephyr picolibc targets without full libc++ headers.
// Phase 184.C — defer to the real libstdc++ <cstring> when reachable (the
// re-export shim breaks via the <string.h> -> <cstring> guard chain on a full
// libstdc++; see cxx-compat/cstdlib). Minimal shim stays for picolibc /
// minimal-libcpp targets (probe header absent).
#if defined(__has_include) && __has_include(<bits/c++config.h>)
#include_next <cstring>
#else
#ifndef NROS_ZEPHYR_CXX_COMPAT_CSTRING
#define NROS_ZEPHYR_CXX_COMPAT_CSTRING
#include <string.h>

namespace std {
using ::memchr;
using ::memcmp;
using ::memcpy;
using ::memmove;
using ::memset;
using ::strcat;
using ::strchr;
using ::strcmp;
using ::strcpy;
using ::strcspn;
using ::strerror;
using ::strlen;
using ::strncat;
using ::strncmp;
using ::strncpy;
using ::strpbrk;
using ::strrchr;
using ::strspn;
using ::strstr;
using ::strtok;
}
#endif  // NROS_ZEPHYR_CXX_COMPAT_CSTRING
#endif  // __has_include(<bits/c++config.h>)
