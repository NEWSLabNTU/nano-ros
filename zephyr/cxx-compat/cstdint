// C++ compat for Zephyr picolibc targets without full libc++ headers.
// Defer to the toolchain's real <cstdint> when reachable; else the shim.
#if defined(__has_include_next) && __has_include_next(<cstdint>)
#  include_next <cstdint>
#elif !defined(NROS_ZEPHYR_CXX_COMPAT_CSTDINT)
#define NROS_ZEPHYR_CXX_COMPAT_CSTDINT
#include <stdint.h>

namespace std {
using ::int16_t;
using ::int32_t;
using ::int64_t;
using ::int8_t;
using ::uint16_t;
using ::uint32_t;
using ::uint64_t;
using ::uint8_t;
}
#endif
