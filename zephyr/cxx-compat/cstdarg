// C++ compat for Zephyr picolibc targets without full libc++ headers.
// Defer to the toolchain's real <cstdarg> when reachable; else the shim.
#if defined(__has_include_next) && __has_include_next(<cstdarg>)
#  include_next <cstdarg>
#elif !defined(NROS_ZEPHYR_CXX_COMPAT_CSTDARG)
#define NROS_ZEPHYR_CXX_COMPAT_CSTDARG
#include <stdarg.h>
#endif
