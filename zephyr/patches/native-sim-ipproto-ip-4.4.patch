+/** IPv4 mreq wire-format (mirrors host `struct ip_mreq`). */
+struct nsos_mid_ip_mreq {
+	uint32_t imr_multiaddr;	/* Multicast group (network byte order) */
+	uint32_t imr_interface;	/* Local interface IP (network byte order) */
+};
