menuconfig NROS
    bool "nros ROS 2 client library"
    help
      Enable nros, a lightweight ROS 2 client library for embedded systems.
      This module supports multiple RMW backends (zenoh-pico, XRCE-DDS)
      selectable via Kconfig.

if NROS

# =============================================================================
# API Selection
# =============================================================================

choice NROS_API
    prompt "nros API language"
    default NROS_RUST_API

config NROS_C_API
    bool "C API (nros-c)"
    help
      Build and link the nros C API library (libnros_c.a).
      Uses nros_* functions from nros/init.h, nros/node.h, etc.

config NROS_CPP_API
    bool "C++ API (nros-cpp)"
    select CPP
    help
      Build and link the nros C++ API library (libnros_cpp.a).
      Uses nros::init(), nros::Node, nros::Publisher<M>, etc.
      Requires C++ support (automatically selected).

config NROS_RUST_API
    bool "Rust API (nros crate)"
    depends on RUST
    help
      Use the nros Rust crate via rust_cargo_application().
      Kconfig values are bridged to Cargo env vars automatically.

endchoice

# =============================================================================
# RMW Backend Selection
# =============================================================================

choice NROS_RMW_BACKEND
    prompt "RMW backend"
    default NROS_RMW_ZENOH

config NROS_RMW_ZENOH
    bool "zenoh-pico"
    help
      Use zenoh-pico as the RMW transport backend.
      Connects to a zenoh router for ROS 2 interop via rmw_zenoh.

config NROS_RMW_XRCE
    bool "XRCE-DDS"
    depends on NET_SOCKETS
    help
      Use Micro-XRCE-DDS as the RMW transport backend.
      Connects to a Micro-XRCE-DDS Agent over UDP sockets.

config NROS_RMW_CYCLONEDDS
    bool "Cyclone DDS (nros-rmw-cyclonedds)"
    depends on NET_SOCKETS && POSIX_API && CPP
    # Phase 11W — universal Cyclone-DDS-on-Zephyr runtime requirements
    # (formerly duplicated in every cyclonedds prj-cyclonedds.conf):
    #   THREAD_LOCAL_STORAGE — Cyclone's `ddsrt_thread_local
    #     tsd_thread_state` needs real per-thread `__thread` storage.
    #   THREAD_CUSTOM_DATA — the cyclonedds-zephyr-threads patch uses
    #     k_thread_custom_data in place of pthread TLS for ddsrt cleanup.
    #   DYNAMIC_THREAD(+ALLOC) — Cyclone's worker threads (gc/recv/
    #     lease/tev) are pthread_create'd with no explicit stack attr;
    #     Zephyr needs the dynamic-thread stack pool or pthread_create
    #     returns EINVAL. THREAD_STACK_INFO + THREAD_MONITOR are
    #     DYNAMIC_THREAD's own dependencies.
    # (NET_TCP — the sockwaitset self-pipe needs it, but selecting it
    #  here forms a Kconfig dependency loop through NET_SOCKETS, so it
    #  stays in the example overlay.)
    # Int knobs (pthread pool sizes, malloc arena, stack size), NET_TCP,
    # and the native_sim-only NSOS socket offload stay in the example
    # overlays.
    # `imply` (not `select`): set most of these on by default but
    # respect each symbol's own dependencies (e.g. THREAD_LOCAL_STORAGE
    # needs ARCH_HAS_THREAD_LOCAL_STORAGE) and avoid select dependency
    # loops. THREAD_CUSTOM_DATA has no extra deps and is required at link
    # time by the CycloneDDS Zephyr thread shim, so select it directly.
    imply THREAD_LOCAL_STORAGE
    select THREAD_CUSTOM_DATA
    imply THREAD_STACK_INFO
    imply THREAD_MONITOR
    imply DYNAMIC_THREAD
    imply DYNAMIC_THREAD_ALLOC
    help
      Use Cyclone DDS (pinned to 0.10.5, matches ros-humble-cyclonedds)
      as the RMW transport backend. Wire-compatible with stock
      rmw_cyclonedds_cpp on the ROS 2 Humble peer side.

      Implementation lives at packages/dds/nros-rmw-cyclonedds/ as a
      standalone C++ project; the Zephyr module compiles the pinned
      Cyclone DDS submodule plus the nros-rmw-cyclonedds register
      glue into the app library. The register entry point
      (`nros_rmw_cyclonedds_register`) is declared with C linkage
      in `nros_rmw_cyclonedds.h`, so both the C API
      (CONFIG_NROS_C_API=y) and C++ API (CONFIG_NROS_CPP_API=y) can
      call it via the Phase 160.A strong-stub emission.

      Phase 117 — see docs/roadmap/phase-117-cyclonedds-rmw.md.
      Phase 168.X gap 2.B dropped the NROS_CPP_API requirement so
      C-API examples can also pick this backend through
      `prj-cyclonedds.conf` overlays.

endchoice

