# C API executor limits are derived from the Rust executor limits below.
# NROS_EXECUTOR_MAX_CBS controls the total handle count for both APIs.

# =============================================================================
# Executor Limits
# =============================================================================

config NROS_EXECUTOR_MAX_CBS
    int "Maximum executor callback slots"
    default 16
    help
      Maximum number of callback slots in the executor
      (subscriptions + timers + services). Controls both Rust and C APIs.
      Arena size is derived automatically from this value and the
      subscription buffer size.

# =============================================================================
# Common Platform Configuration
# =============================================================================

config NROS_DOMAIN_ID
    int "ROS 2 Domain ID"
    default 0
    help
      ROS 2 domain ID for topic isolation.

config NROS_INIT_DELAY_MS
    int "Network initialization delay (ms)"
    default 2000
    help
      Maximum time to wait for the network interface to come up
      before initializing the RMW transport.

# =============================================================================
# Host-side codegen tool (cross-compile fix-up)
# =============================================================================

config NROS_CODEGEN_TOOL
    string "Path to host-built nros-codegen binary"
    default ""
    help
      Phase 140 — Zephyr builds cross-compile for the target, but
      nros-codegen runs on the build host. Build it once via a
      parallel POSIX configure:

        cmake -S <nano-ros> -B build-host -DNANO_ROS_PLATFORM=posix
        cmake --build build-host --target nros-codegen

      and point this Kconfig at the resulting binary
      (e.g. /home/user/nano-ros/build-host/<...>/nros-codegen).

      The Zephyr module's nros_generate_interfaces() picks it up
      automatically when set. Without this (and without the binary
      on PATH), configure errors out with a Hint.

endif # NROS
