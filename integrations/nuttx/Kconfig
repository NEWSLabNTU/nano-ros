# Phase 139.4 / 152.7 / 157.B — Kconfig surfaced under
# `Application Configuration → External Modules → nano-ros`.
#
# 152.7 — promoted free-form `string` knobs to `choice` so
# `make menuconfig` drives Cargo `--features` cleanly via the
# matching `CONFIG_NROS_RMW_*` / `CONFIG_NROS_ROS_*` symbols read
# by the sibling `Makefile`.
#
# 157.B — this file is the integration shell's own Kconfig,
# discovered by NuttX once symlinked to `apps/external/nano-ros/`
# AND the Phase 157.C staging script has copied
# `external-Kconfig.in` to `apps/external/Kconfig` (which
# osource-globs every `apps/external/*/Kconfig`). Example apps
# (apps/external/nano-ros-talker-c/Kconfig etc.) are discovered
# as separate apps/external/ siblings via that same glob. Example
# Kconfigs depend on NROS_C_API / NROS_CPP_API (declared below)
# so menuconfig only shows examples whose host API is enabled.

config NROS
    bool "nano-ros ROS 2 client"
    default n
    help
      Enables the nano-ros Cargo-built static library in the NuttX
      build. Cargo runs in NuttX's `context::` phase via the
      upstream `apps/tools/Rust.mk` macros; the resulting
      `libnros_c.a` (and optionally `libnros_cpp.a`) is appended to
      `EXTRA_LIBS` for the monolithic link.

if NROS

choice
    prompt "RMW backend"
    default NROS_RMW_ZENOH
    help
      Selects the ROS 2 middleware nano-ros uses. The choice flips
      the matching `--features rmw-<name>` Cargo flag in the
      sibling Makefile.

config NROS_RMW_ZENOH
    bool "Zenoh (zenoh-pico)"
    help
      Embedded zenoh client; full ROS 2 graph support, low
      footprint. Recommended default for most NuttX boards.

config NROS_RMW_XRCE
    bool "XRCE-DDS (micro-XRCE-DDS-Client)"
    help
      Lightweight XRCE-DDS client; needs a Micro-XRCE-DDS Agent
      bridge on the host side.

config NROS_RMW_CYCLONEDDS
    bool "Cyclone DDS"
    help
      Eclipse Cyclone DDS via the rmw_cyclonedds_cpp bridge.
      Largest footprint; pick only if Cyclone-specific QoS knobs
      matter to you.

endchoice

choice
    prompt "ROS 2 edition"
    default NROS_ROS_HUMBLE

config NROS_ROS_HUMBLE
    bool "Humble"

config NROS_ROS_IRON
    bool "Iron"

endchoice

# Phase 157 — language API selectors. The C surface always builds
# (cargo features `rmw-cffi` already pulls nros-c), but the C++
# surface is opt-in because it doubles the Cargo build time +
# adds ~80 KB to the link. External-app examples key their
# Kconfig depends on these two so the menu only shows examples
# whose host API is actually enabled.

config NROS_C_API
    bool "C API surface (nros-c)"
    default y
    help
      Enables the nros-c C API. Required by every C-language
      external-app example (`apps/external/nano-ros-*-c/`).
      Disable to skip the nros-c staticlib build for C++-only
      deployments.

config NROS_CPP_API
    bool "C++ API surface (nros-cpp)"
    default n
    help
      Enables the nros-cpp C++ API. Required by every
      C++-language external-app example
      (`apps/external/nano-ros-*-cpp/`). Adds ~80 KB to the
      link + an extra Cargo build cycle.

endif # NROS
