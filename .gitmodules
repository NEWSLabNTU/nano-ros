[submodule "third-party/qemu/qemu"]
	path = third-party/qemu/qemu
	url = https://github.com/NEWSLabNTU/qemu.git
	branch = nano-ros-v11.0.0-patches
	# NEWSLabNTU/qemu fork carries the nano-ros patch set on top of
	# upstream QEMU release tags. Bump the submodule pointer to the
	# fork's latest patched commit; the legacy patches/ dir was
	# removed since the patches live in the fork's git history now.
