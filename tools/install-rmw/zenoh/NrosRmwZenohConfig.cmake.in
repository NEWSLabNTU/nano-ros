@PACKAGE_INIT@

# Phase 123.A.1.x.4.a — `find_package(NrosRmwZenoh CONFIG)` exposes
# the imported target `NrosRmwZenoh::NrosRmwZenoh`, a STATIC IMPORTED
# library pointing at `libnros_rmw_zenoh.a` (renamed from cargo's
# `libnros_rmw_zenoh_staticlib.a` at install time).
#
# Downstream linking requires `--allow-multiple-definition` (GNU ld
# / lld) to reconcile the per-archive copies of `compiler_builtins`
# shared with `libnros_c.a`.

include("${CMAKE_CURRENT_LIST_DIR}/NrosRmwZenohTargets.cmake")

check_required_components(NrosRmwZenoh)
