# editor
*~
.*~
*.sw[op]
\#*#

# Python caches
__pycache__/
*.py[oc]

# Rust
/target/

# Build output (created by: just install-local)
/build/

# Distribution archives created by: just package
/nros-*.tar.gz
/nros-*.zip

# Zephyr workspace symlink (user-specific, created by scripts/zephyr/setup.sh)
/zephyr-workspace

# px4-rs symlink (user-specific, created by: just px4 setup)
/third-party/px4-rs

# Generated message bindings in examples (recreated by: just generate-bindings)
# NOTE: packages/interfaces/rcl-interfaces/generated/ is NOT gitignored — it's a workspace member
examples/**/generated/

# Verus binary (downloaded by: just setup-verus)
tools/*
# ...but keep the pinned nightly for workspace tooling (fmt/miri/llvm-cov/etc.)
!tools/rust-toolchain.toml

# Local environment overrides (created from .env.example)
/.env
