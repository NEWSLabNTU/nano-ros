# editor
*~
.*~
*.sw[op]
\#*#

# Python caches
__pycache__/
*.py[oc]

# Rust
/target/
**/target/
# Phase 150.E rev3 ‚Äî deterministic --target-dir for the shared
# `nros-tests::zenoh_header_parity` + `zenoh_archive_symbols`
# POSIX fixture (`just build-zenoh-posix-fixture`).
/target-zenoh-fixture-posix/

# Build output (per-example cmake build dirs, zenohd / zenoh-pico
# scratch trees, Phase 138 Corrosion outputs). Phase 140 deleted the
# install-local pipeline; build/ now only holds transient compile
# artefacts.
/build/

# Zephyr workspace symlink (user-specific, created by scripts/zephyr/setup.sh)
/zephyr-workspace
# ESP-IDF workspace (user-specific, created by scripts/esp_idf/setup.sh).
# Pulled only when nros-platform-esp-idf-c is in use; not part of the
# default esp32 (esp-hal bare-metal) build path.
/esp-idf-workspace

# Generated message bindings in examples (recreated by: just generate-bindings)
# NOTE: packages/interfaces/rcl-interfaces/generated/ is NOT gitignored ‚Äî it's a workspace member
examples/**/generated/
**/generated/.nros-generate-rust.sig

# Verus binary (downloaded by: just setup-verus)
tools/*
# ...but keep the pinned nightly for workspace tooling (fmt/miri/llvm-cov/etc.)
!tools/rust-toolchain.toml
# Phase 123.A.3 ‚Äî setup orchestrator (target ‚Üí submodule fetch).
!tools/setup.sh
# Phase 197.4 ‚Äî host-env helper (rustup/apt for `just <module> setup`).
!tools/host-env.sh

# Local environment overrides (created from .env.example)
/.env

# Per-CLAUDE.md, throwaway scripts and notes go in tmp/ (project root,
# not /tmp). Recipes for repeated multi-step ops live here too.
/tmp/

# Third-party reference repos (cloned ad-hoc for cross-checking
# upstream source ‚Äî Phase 100 SPE port pulls FreeRTOS-Kernel here for
# its Cortex-R5 GCC port + POSIX simulator port).
# Per-session scratch ‚Äî CLAUDE.md "Temp files in $project/tmp/ (gitignored)".
/tmp/
# Test runner log dir created by tests/run-test.sh.
/test-logs/
# One-off build smoke logs (e.g. just zephyr build-s32z's best-effort log).
/build-*.log
# XRCE agent stdout/stderr captured by nros-tests fixture (per port).
/xrce-agent-*.log
# Claude Code session/agent state.
/.claude/
/external/
/third-party/make/
/third-party/ninja/
/nros-0.1.0-linux-x86_64.tar.gz
/target-zpico-build-matrix/
/target-zpico-drift-gate/

# Per-developer local Claude Code settings
.claude/settings.local.json

# Per-machine SDK resolution lock written by `nros setup`
/nros-sdk.lock

# Phase 193 ‚Äî separate target-dir for concurrent embedded clippy (just check-workspace-all)
/target-embedded/

# Per-RMW example build dirs (target-xrce/ etc.) ‚Äî build output, never committed
examples/**/target-*/

# Phase 277 W7 ‚Äî standalone example/workspace Cargo.locks are never committed.
# They are not reproducibility-critical (scripts/build/cargo.sh prefetch
# refreshes them without --locked) and committed copies go stale (known-issue
# pattern: locks pinning nros-core 0.1.0 after the 218.J bump).
examples/**/Cargo.lock
/nros-patch.toml
